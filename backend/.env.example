# Copier vers .env en local. Sur Render : Environment -> ajouter chaque cle.

NODE_ENV=production

# Render injecte PORT ; ne pas fixer en prod hebergee sauf besoin.
# PORT=3000

# SMTP (envoi e-mails) — au moins un provider requis pour la réinitialisation mot de passe
#
# Option A — Gmail (mot de passe d'application, pas le mot de passe du compte)
# 1. Compte Google → Sécurité → Validation en 2 étapes activée
# 2. Mots de passe des applications → créer un mot de passe pour "HeadsApp"
# 3. Coller le code 16 caractères ci-dessous (espaces optionnels)
SMTP_USER=onsyoussef5@gmail.com
SMTP_PASS=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
#
# Option B — Brevo (recommandé si Gmail refuse BadCredentials)
# BREVO_API_KEY=xkeysib-votre-cle
# EMAIL_FROM=HeadsApp <noreply@votredomaine.com>
#
# Option C — Resend
# RESEND_API_KEY=re_votre_cle
# EMAIL_FROM=HeadsApp <onboarding@resend.dev>
#
# Debug local : afficher aussi le code dans le terminal après envoi réussi
# SMTP_DEV_LOG=true

# Securite
JWT_SECRET=8f2c6b7d9e4a1f3c5b8e2d7a9c1f4e6b3d8a2f7c9e5b1a4d6f3c8e2a7b9d1f4
# Panel admin HeadsApp
ADMIN_API_KEY=headsapp_admin_super_secret_2026_#Tn
ADMIN_EMAIL=wijden@headsapp.com
ADMIN_PASSWORD=wijden maalaoui@2026
ADMIN_NAME=wijden maalaoui
# Chiffrement donnees sensibles (AES-256-GCM) + hash email (HMAC-SHA256)
# ENCRYPTION_KEY = 64 caracteres hex (32 bytes). NE PAS laisser le placeholder.
# Generer : cd backend && npm run generate-crypto-keys
ENCRYPTION_KEY=replace-with-64-hex-characters
HMAC_KEY=replace-with-strong-hmac-secret

# MongoDB
MONGODB_URI=mongodb+srv://onsyoussef5_db_user:hanen248@cluster0.roqve4j.mongodb.net/telemedecine?retryWrites=true&w=majority
# Si querySrv ETIMEOUT : URI standard sans +srv (Atlas → Connect → Drivers)
# MONGODB_URI_STANDARD=mongodb://host1,host2/telemedecine?retryWrites=true&w=majority

# CORS — origines autorisées (front web Flutter, admin Vite, Render). Copier aussi dans Render → Environment.
ALLOWED_ORIGINS=https://projetpfe-8vrx.onrender.com,http://localhost:*,http://127.0.0.1:*,http://[::1]:*
# Dev depuis une autre machine sur le reseau local (optionnel)
# CORS_ALLOW_LAN=true

